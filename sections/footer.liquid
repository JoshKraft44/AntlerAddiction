{% comment %}theme-check-disable UndefinedObject{% endcomment %}

<style>
  .custom-footer {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 60px 0 0;
    margin-top: {{ section.settings.margin_top }}px;
    border-top: 1px solid #d9d9d9;
  }

  .custom-footer * {
    box-sizing: border-box;
  }

  .custom-footer a {
    color: {{ section.settings.text_color }};
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .custom-footer a:hover {
    opacity: 0.7;
  }

  .custom-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .custom-footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.4fr;
    gap: 40px;
  }

  /* ---- Column headings ---- */
  .custom-footer__heading {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin: 0 0 24px;
    color: {{ section.settings.text_color }};
  }

  /* ---- Column 1: Brand ---- */
  .custom-footer__brand-name {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin: 0 0 16px;
    color: {{ section.settings.text_color }};
  }

  .custom-footer__copyright {
    font-size: 12px;
    line-height: 1.7;
    opacity: 0.6;
    margin: 0 0 24px;
  }

  .custom-footer__social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 16px;
  }

  .custom-footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  .custom-footer__social svg {
    width: 20px;
    height: 20px;
    fill: {{ section.settings.text_color }};
  }

  /* ---- Columns 2 & 3: Link lists ---- */
  .custom-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .custom-footer__links li {
    margin-bottom: 10px;
  }

  .custom-footer__links a {
    font-size: 13px;
    line-height: 1.6;
    opacity: 0.75;
    position: relative;
  }

  .custom-footer__links a::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: {{ section.settings.text_color }};
    transition: width 0.25s ease;
  }

  .custom-footer__links a:hover {
    opacity: 1;
  }

  .custom-footer__links a:hover::after {
    width: 100%;
  }

  /* ---- Column 4: Newsletter ---- */
  .custom-footer__subscribe-text {
    font-size: 13px;
    line-height: 1.6;
    opacity: 0.75;
    margin: 0 0 20px;
  }

  .custom-footer__form-wrapper {
    position: relative;
  }

  .custom-footer__email-input {
    width: 100%;
    background: transparent;
    border: 1px solid rgba({{ section.settings.text_color_rgb }}, 0.8);
    border-radius: 0;
    padding: 12px 14px;
    font-size: 13px;
    color: {{ section.settings.text_color }};
    outline: none;
    transition: border-color 0.2s ease;
    font-family: inherit;
  }

  .custom-footer__email-input::placeholder {
    color: {{ section.settings.text_color }};
    opacity: 0.45;
  }

  .custom-footer__email-input:focus {
    border-color: {{ section.settings.text_color }};
  }

  .custom-footer__submit-btn {
    background: transparent;
    border: none;
    color: {{ section.settings.text_color }};
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    padding: 22px 0 0;
    font-family: inherit;
    transition: opacity 0.2s ease;
  }

  .custom-footer__submit-btn:hover {
    opacity: 0.7;
  }

  .custom-footer__form-message {
    font-size: 12px;
    margin-top: 8px;
  }

  .custom-footer__form-message--error {
    color: #e57373;
  }

  .custom-footer__form-message--success {
    color: #81c784;
  }

  /* ---- Bottom bar ---- */
  .custom-footer__bottom {
    margin-top: 48px;
    border-top: 1px solid rgba({{ section.settings.text_color_rgb }}, 0.15);
    padding: 20px 0;
    background-color: #f4f0eb;
  }

  .custom-footer__bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    overflow: hidden;
  }

  .custom-footer__payment {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .custom-footer__payment li {
    background: none;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .custom-footer__payment svg {
    height: 24px;
    width: auto;
  }

  .custom-footer__payment svg > rect,
  .custom-footer__payment svg > path[opacity],
  .custom-footer__payment svg > path:first-child {
    display: none !important;
  }

  /* Ensure the bottom bar is visible above any Shopify wrappers */
  .custom-footer__bottom,
  .custom-footer__bottom * {
    visibility: visible !important;
    opacity: 1 !important;
  }

  /* ---- TABLET (2x2) ---- */
  @media (max-width: 999px) {
    .custom-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px 32px;
    }
  }

  /* ---- MOBILE (single stack) ---- */
  @media (max-width: 599px) {
    .custom-footer {
      padding: 40px 0 0;
    }

    .custom-footer__inner {
      padding: 0 24px;
    }

    .custom-footer__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .custom-footer__bottom-inner {
      padding: 0 24px;
      justify-content: center;
    }
  }
</style>

<footer class="custom-footer" role="contentinfo">
  <div class="custom-footer__inner">
    <div class="custom-footer__grid">

      {%- comment -%} COLUMN 1 — Brand {%- endcomment -%}
      <div class="custom-footer__col">
        <p class="custom-footer__brand-name">{{ shop.name }}</p>
        <div class="custom-footer__copyright">
          <p style="margin: 0;">Copyright &copy; {{ shop.name }}</p>
          <p style="margin: 0;">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
        </div>

        {%- assign has_social = true -%}

        {%- if has_social -%}
          <ul class="custom-footer__social" role="list">
            {%- if settings.social_instagram_link != blank -%}
              <li>
                <a href="{{ settings.social_instagram_link }}" aria-label="Instagram" target="_blank" rel="noopener">
