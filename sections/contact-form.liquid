{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* ===== INPUT FIXES ===== */
  .field__input {
    line-height: normal !important;
    height: auto !important;
    min-height: 42px;
    padding: 0.75rem !important;
    vertical-align: middle !important;
    caret-color: currentColor !important;
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"] {
    appearance: none !important;
    -webkit-appearance: none !important;
    -moz-appearance: none !important;
  }

  .field__input:focus {
    transform: none !important;
  }

  textarea.field__input {
    padding-top: 0.75rem !important;
    line-height: 1.5 !important;
    vertical-align: top !important;
  }

  .field__input,
  .field__label {
    transition: none !important;
    animation: none !important;
  }

  @media not all and (min-resolution:.001dpcm) {
    @supports (-webkit-appearance:none) {
      .field__input {
        padding-top: 0.85rem !important;
        padding-bottom: 0.85rem !important;
      }
    }
  }

  /* ===== PAGE LAYOUT ===== */
  .contact-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 40px 5rem;
  }

  /* ===== HEADER ===== */
  .contact-page__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .contact-page__title {
    font-size: 32px;
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
  }

  .contact-page__subtitle {
    font-size: 15px;
    color: #4a4a4a;
    line-height: 1.6;
    margin: 0;
  }

  .contact-page__subtitle a {
    color: #1a1a1a;
    text-decoration: none;
    border-bottom: 1px solid #d9d9d9;
    transition: border-color 0.2s ease;
  }

  .contact-page__subtitle a:hover {
    border-bottom-color: #1a1a1a;
  }

  /* ===== FORM ===== */
  .contact-page__form-wrap {
    margin-bottom: 3rem;
  }

  .contact__fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact__fields .field--full {
    grid-column: 1 / -1;
  }

  .field {
    margin-bottom: 0;
    position: relative;
  }

  /* Visually hidden labels (accessibility) */
  .field__label {
    border: 0 !important;
    clip: rect(0 0 0 0) !important;
    clip-path: inset(50%) !important;
    height: 1px !important;
    margin: -1px !important;
    overflow: hidden !important;
    padding: 0 !important;
    position: absolute !important;
    white-space: nowrap !important;
    width: 1px !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  .field__input:focus + .field__label,
  .field__input:not(:placeholder-shown) + .field__label {
    transform: none !important;
    opacity: 0 !important;
    display: none !important;
  }

  .field__input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid rgba(26, 26, 26, 0.25);
    border-radius: 0;
    background-color: transparent;
    outline: none;
    text-align: left;
    line-height: normal;
    font-size: 14px;
    color: #1a1a1a;
    font-family: inherit;
    transition: border-color 0.2s ease;
  }

  .field__input:hover {
    border-color: rgba(26, 26, 26, 0.5);
    background-color: transparent;
  }

  .field__input:focus {
    background-color: transparent;
    border-color: #1a1a1a;
    box-shadow: none;
    outline: none;
  }

  .field__input::placeholder {
    color: #1a1a1a;
    opacity: 0.4;
  }

  .field__input:focus::placeholder {
    opacity: 0.25;
  }

  textarea.text-area {
    height: 160px;
    resize: vertical;
    width: 100%;
    line-height: 1.6;
    font-family: inherit;
  }

  /* ===== BUTTON ===== */
  .contact__button {
    margin-top: 1.5rem;
  }

  button.button {
    display: inline-block;
    padding: 12px 28px;
    background-color: transparent;
    color: #1a1a1a;
    border: 2px solid #1a1a1a;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-family: inherit;
    transition: background-color 0.2s ease, color 0.2s ease;
    box-shadow: none;
    overflow: visible;
  }

  button.button::before {
    display: none;
  }

  button.button:hover {
    background-color: #1a1a1a;
    color: #ffffff;
    transform: none;
    box-shadow: none;
  }

  button.button:active {
    opacity: 0.9;
  }

  /* ===== EMAIL CALLOUT ===== */
  .contact-page__email {
    text-align: center;
    padding-top: 2.5rem;
    border-top: 1px solid #d9d9d9;
  }

  .contact-page__email-label {
    font-size: 12px;
    font-weight: 500;
    color: #1a1a1a;
    opacity: 0.5;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  .contact-page__email-link {
    display: inline-block;
    color: #1a1a1a;
    text-decoration: none;
    font-size: 15px;
    font-weight: 400;
    position: relative;
  }

  .contact-page__email-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: #1a1a1a;
    transition: width 0.25s ease;
  }

  .contact-page__email-link:hover::after {
    width: 100%;
  }

  /* ===== STATUS MESSAGES ===== */
  .form-status {
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    border-radius: 0;
    font-size: 14px;
  }

  .form-status--success {
    background-color: #f0f7f0;
    border: 1px solid #a8d5a8;
    color: #2e5c2e;
  }

  .form-status--error {
    background-color: #ffebee;
    border: 1px solid #e57373;
    color: #c62828;
  }

  .contact__field-error {
    color: #c62828;
    font-size: 13px;
    margin-top: 0.5rem;
    display: block;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .contact-page {
      padding: 3rem 24px 4rem;
    }

    .contact-page__title {
      font-size: 26px;
    }

    .contact__fields {
      grid-template-columns: 1fr;
    }

    button.button {
      width: 100%;
      padding: 14px 28px;
    }
  }

  @media (max-width: 480px) {
    .contact-page {
      padding: 2.5rem 16px 3rem;
    }

    .contact-page__title {
      font-size: 24px;
    }
  }

{%- endstyle -%}

<div class="contact-page">
  <div class="contact-page__header">
    <h1 class="contact-page__title">Get in Touch</h1>
    <p class="contact-page__subtitle">Have a question about sizing, selection, or your order? We’re happy to help.</p>
  </div>

  <div class="contact-page__form-wrap">
    {%- form 'contact', id: 'ContactForm', class: 'isolate' -%}
      {%- if form.posted_successfully? -%}
        <div class="form-status form-status--success" tabindex="-1" autofocus>
          {{ 'templates.contact.form.post_success' | t }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="form-status form-status--error">
          <h2 class="visually-hidden">{{ 'accessibility.error' | t }}</h2>
          <div class="form__message" tabindex="-1" autofocus>
            {{ form.errors | default_errors }}
          </div>
        </div>
      {%- endif -%}

      <div class="contact__fields">
        <div class="field">
          <label class="field__label" for="ContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
          <input
            class="field__input"
            autocomplete="name"
            type="text"
            id="ContactForm-name"
            name="contact[{{ 'templates.contact.form.name' | t }}]"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            placeholder="{{ 'templates.contact.form.name' | t }}"
            required>
        </div>

        <div class="field field--with-error">
          <label class="field__label" for="ContactForm-email">{{ 'templates.contact.form.email' | t }}</label>
          <input
            autocomplete="email"
            type="email"
            id="ContactForm-email"
            class="field__input"
            name="contact[email]"
            spellcheck="false"
            autocapitalize="off"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            aria-required="true"
            {% if form.errors contains 'email' %}
              aria-invalid="true"
              aria-describedby="ContactForm-email-error"
            {% endif %}
            placeholder="{{ 'templates.contact.form.email' | t }} *"
            required>
          {%- if form.errors contains 'email' -%}
            <small class="contact__field-error" id="ContactForm-email-error">
              <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
              <span>{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}.</span>
            </small>
          {%- endif -%}
        </div>

        <div class="field field--full">
          <label class="field__label" for="ContactForm-body">{{ 'templates.contact.form.comment' | t }}</label>
          <textarea
            rows="10"
            id="ContactForm-body"
            class="text-area field__input"
            name="contact[{{ 'templates.contact.form.comment' | t }}]"
            placeholder="{{ 'templates.contact.form.comment' | t }}"
            required>{%- if form.body -%}{{ form.body }}{%- endif -%}</textarea>
        </div>
      </div>

      <div class="contact__button">
        <button type="submit" class="button">{{ 'templates.contact.form.send' | t }}</button>
      </div>
    {%- endform -%}
  </div>

  <div class="contact-page__email">
    <p class="contact-page__email-label">Or email us directly</p>
    <a href="mailto:support@antleraddiction.ca" class="contact-page__email-link">support@antleraddiction.ca</a>
  </div>
</div>

{% schema %}
{
  "name": "Custom Contact Form",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "background-1" },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Padding top", "default": 36 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 36 }
  ],
  "presets": [ { "name": "Custom Contact Form" } ]
}
{% endschema %}
