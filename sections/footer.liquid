                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_facebook_link != blank -%}
              <li>
                <a href="{{ settings.social_facebook_link }}" aria-label="Facebook" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_pinterest_link != blank -%}
              <li>
                <a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.988-5.367 11.988-11.992C24.005 5.367 18.641 0 12.017 0z"/></svg>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <li>
                <a href="{{ settings.social_tiktok_link }}" aria-label="TikTok" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <li>
                <a href="{{ settings.social_youtube_link }}" aria-label="YouTube" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <li>
                <a href="{{ settings.social_twitter_link }}" aria-label="Twitter" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_snapchat_link != blank -%}
              <li>
                <a href="{{ settings.social_snapchat_link }}" aria-label="Snapchat" target="_blank" rel="noopener">
                  {%- render 'icon-snapchat' -%}
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_tumblr_link != blank -%}
              <li>
                <a href="{{ settings.social_tumblr_link }}" aria-label="Tumblr" target="_blank" rel="noopener">
                  {%- render 'icon-tumblr' -%}
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_vimeo_link != blank -%}
              <li>
                <a href="{{ settings.social_vimeo_link }}" aria-label="Vimeo" target="_blank" rel="noopener">
                  {%- render 'icon-vimeo' -%}
                </a>
              </li>
            {%- endif -%}
            <li>
              <a href="http://antleraddictionab.etsy.com/" aria-label="Etsy" target="_blank" rel="noopener">
                {%- render 'icon-etsy' -%}
              </a>
            </li>
          </ul>
        {%- endif -%}

      </div>

      {%- comment -%} COLUMN 2 — About / Navigation {%- endcomment -%}
      <div class="custom-footer__col">
        <h2 class="custom-footer__heading">{{ section.settings.menu_heading }}</h2>
        {%- if section.settings.menu != blank -%}
          <ul class="custom-footer__links">
            {%- for link in section.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {%- comment -%} COLUMN 3 — Policies {%- endcomment -%}
      <div class="custom-footer__col">
        <h2 class="custom-footer__heading">{{ section.settings.policies_heading }}</h2>
        {%- if section.settings.policies_menu != blank -%}
          <ul class="custom-footer__links">
            {%- for link in section.settings.policies_menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {%- comment -%} COLUMN 4 — Newsletter {%- endcomment -%}
      <div class="custom-footer__col">
        <h2 class="custom-footer__heading">{{ section.settings.subscribe_heading }}</h2>
        <p class="custom-footer__subscribe-text">{{ section.settings.subscribe_text }}</p>

        {%- form 'customer', id: 'FooterNewsletter', class: 'custom-footer__form-wrapper' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="FooterEmail--{{ section.id }}">{{ 'newsletter.label' | t }}</label>
          <input
            id="FooterEmail--{{ section.id }}"
            type="email"
            name="contact[email]"
            class="custom-footer__email-input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            placeholder="Email address"
            required
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="FooterNewsletter-error"
            {% elsif form.posted_successfully? %}
              aria-describedby="FooterNewsletter-success"
            {% endif %}
          >
          <button type="submit" class="custom-footer__submit-btn">Subscribe</button>

          {%- if form.errors -%}
            <p class="custom-footer__form-message custom-footer__form-message--error" id="FooterNewsletter-error">
              {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
            </p>
          {%- endif -%}
          {%- if form.posted_successfully? -%}
            <p class="custom-footer__form-message custom-footer__form-message--success" id="FooterNewsletter-success">
              {{ 'newsletter.success' | t }}
            </p>
          {%- endif -%}
        {%- endform -%}
      </div>

    </div>
  </div>

  {%- comment -%} BOTTOM BAR {%- endcomment -%}
  {%- if section.settings.payment_enable -%}
    <div class="custom-footer__bottom">
      <div class="custom-footer__bottom-inner">
        <ul class="custom-footer__payment" role="list">
          <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
          {%- for type in shop.enabled_payment_types -%}
            <li>{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  {%- endif -%}
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#3B3228"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#F5F0EB"
    },
    {
      "type": "text",
      "id": "text_color_rgb",
      "label": "Text color (RGB values for borders)",
      "default": "245, 240, 235",
      "info": "Enter the RGB values of your text color, e.g. 245, 240, 235"
    },
    {
      "type": "header",
      "content": "Navigation column"
    },
    {
      "type": "text",
      "id": "menu_heading",
      "label": "Column heading",
      "default": "ABOUT"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Policies column"
    },
    {
      "type": "text",
      "id": "policies_heading",
      "label": "Column heading",
      "default": "POLICIES"
    },
    {
      "type": "link_list",
      "id": "policies_menu",
      "label": "Policies menu"
    },
    {
      "type": "header",
      "content": "Newsletter column"
    },
    {
      "type": "text",
      "id": "subscribe_heading",
      "label": "Heading",
      "default": "HEY!"
    },
    {
      "type": "textarea",
      "id": "subscribe_text",
      "label": "Description",
      "default": "Enter your email to stay in the loop on new collections, sales and more."
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 0
    }
  ]
}
{% endschema %}